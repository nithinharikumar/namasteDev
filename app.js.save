//component composition is  writing  the component   inside another componetn 
const Title = () => (
    <h1>the hedaing is here  funde   main aanu myre</h1>
)
const elem = (<span>the span is heerer</span>)
const Titlen = (<div>  < h1 > the   react element is here</h1><HeadingComponent /></div>)
const HeadingComponent = () => (
    <>
        {Titlen}
        {elem}
        <Title />
        <h1>the hedaing is here  funde</h1>
        <p>the hedaing and  paragraph  </p>
        <img src="https://dummyimage.com/600x400/000/fff" alt="" />
    </>
)
const root = ReactDOM.createRoot(document.getElementById("root"));
root.render(<HeadingComponent />);
